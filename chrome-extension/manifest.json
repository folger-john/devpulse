{
  "manifest_version": 3,
  "name": "DevPulse Developer Tools",
  "version": "1.0.0",
  "description": "Quick access to 25+ developer tools — JSON formatter, Base64, UUID, Hash, Password, Timestamps & more. Paste anything, auto-detected instantly.",
  "homepage_url": "https://devpulse.tools",
  "permissions": ["contextMenus", "activeTab"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "DevPulse Tools"
  },
  "background": {
    "service_worker": "background.js"
  }
}
